# ─────────────────────────────────────────────
# Story Land Food Safety System — API
# Copia este archivo como .env y llena los valores
# NUNCA subas .env a GitHub
# ─────────────────────────────────────────────

# ── Base de datos (PostgreSQL en Railway) ─────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/storyland_db?schema=public"

# ── Redis (Railway) ───────────────────────────
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# ── JWT ───────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="reemplaza-con-un-secreto-largo-y-seguro-de-al-menos-64-caracteres"
JWT_EXPIRES_IN="7d"

# ── Servidor ──────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ── Email (alertas de temperatura) ───────────
# Para desarrollo: usar Mailtrap https://mailtrap.io (gratis)
# Para producción: usar Resend https://resend.com o SendGrid
SMTP_HOST="sandbox.smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="tu_usuario_mailtrap"
SMTP_PASS="tu_password_mailtrap"

# Email del admin que recibe alertas de temperatura fuera de rango
ADMIN_ALERT_EMAIL="admin@storyland.com"
